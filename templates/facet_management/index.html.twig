{% extends 'base.html.twig' %}

{% block title %}Faceting management{% endblock %}

{% block body %}
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h1 class="h3 mb-2">Faceting management</h1>
                            <p class="text-secondary mb-0">Current demo facet surface for the component.</p>
                        </div>
                        <span class="badge text-bg-primary" data-testid="facet-total">{{ facetTotal }}</span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Listing filters</h2>
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="type">Type</label>
                            <select class="form-select" id="type" name="type">
                                <option value="">All</option>
                                <option value="term"{{ listingCriteria.type == 'term' ? ' selected' : '' }}>Term</option>
                                <option value="range"{{ listingCriteria.type == 'range' ? ' selected' : '' }}>Range</option>
                                <option value="boolean"{{ listingCriteria.type == 'boolean' ? ' selected' : '' }}>Boolean</option>
                                <option value="hierarchy"{{ listingCriteria.type == 'hierarchy' ? ' selected' : '' }}>Hierarchy</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="visible">Visible</label>
                            <select class="form-select" id="visible" name="visible">
                                <option value="true"{{ listingCriteria.visible is same as(true) ? ' selected' : '' }}>Visible only</option>
                                <option value="false"{{ listingCriteria.visible is same as(false) ? ' selected' : '' }}>Hidden only</option>
                                <option value=""{{ listingCriteria.visible is null ? ' selected' : '' }}>Any</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="search">Search</label>
                            <input class="form-control" id="search" name="search" value="{{ listingCriteria.search ?? '' }}">
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Apply filters</button>
                            <a href="/faceting/management/facets" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h3 class="h6 mb-3">Type aggregation</h3>
                                <ul class="list-unstyled mb-0">
                                    {% for bucket in facetAggregations.types %}
                                        <li class="d-flex justify-content-between">
                                            <span>{{ bucket.key|title }}</span>
                                            <span class="badge text-bg-light">{{ bucket.count }}</span>
                                        </li>
                                    {% else %}
                                        <li class="text-secondary">No type buckets available.</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h3 class="h6 mb-3">Visibility aggregation</h3>
                                <ul class="list-unstyled mb-0">
                                    {% for bucket in facetAggregations.visibility %}
                                        <li class="d-flex justify-content-between">
                                            <span>{{ bucket.key|title }}</span>
                                            <span class="badge text-bg-light">{{ bucket.count }}</span>
                                        </li>
                                    {% else %}
                                        <li class="text-secondary">No visibility buckets available.</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                        <tr>
                            <th scope="col">Code</th>
                            <th scope="col">Name</th>
                            <th scope="col">Type</th>
                            <th scope="col">Visible</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for facet in facets %}
                            <tr>
                                <td>{{ facet.code }}</td>
                                <td>{{ facet.name }}</td>
                                <td>{{ facet.type }}</td>
                                <td>{{ facet.visible ? 'yes' : 'no' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-secondary">No facets matched the current criteria.</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            {{ form_start(facetForm, {attr: {class: 'card shadow-sm'}}) }}
                <div class="card-body">
                    <h2 class="h4 mb-3">Facet preview</h2>
                    <div class="row g-3">
                        <div class="col-12">
                            {{ form_row(facetForm.code) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(facetForm.name) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(facetForm.type) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(facetForm.visible) }}
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pt-0">
                    <button type="submit" class="btn btn-success">Generate preview</button>
                </div>
            {{ form_end(facetForm) }}

            {% if materializedFacet is not null %}
                <div class="card shadow-sm mt-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Materialized facet</h2>
                        <pre class="mb-0">{{ materializedFacet|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
