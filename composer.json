{
    "name": "smartresponsor/faceting",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "symfony/console": "7.3.*",
        "symfony/dotenv": "7.3.*",
        "symfony/error-handler": "7.3.*",
        "symfony/form": "7.3.*",
        "symfony/framework-bundle": "7.3.*",
        "symfony/runtime": "7.3.*",
        "symfony/security-bundle": "7.3.*",
        "symfony/twig-bundle": "7.3.*",
        "symfony/validator": "7.3.*",
        "symfony/yaml": "7.3.*"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^10.5",
        "symfony/browser-kit": "7.3.*",
        "symfony/css-selector": "7.3.*",
        "symfony/dom-crawler": "7.3.*",
        "symfony/phpunit-bridge": "7.3.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint:php": [
            "php -l src/Kernel.php",
            "php -l bin/console",
            "php -l public/index.php"
        ],
        "lint:yaml": "php bin/console lint:yaml config --parse-tags",
        "lint:twig": "php bin/console lint:twig templates",
        "lint:container": "php bin/console lint:container",
        "cs:check": [
            "@lint:php"
        ],
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:functional": "phpunit --testsuite functional",
        "test": [
            "@test:unit",
            "@test:integration",
            "@test:functional"
        ],
        "pipeline:local:full": [
            "@lint:php",
            "@lint:yaml",
            "@lint:twig",
            "@lint:container",
            "@test"
        ]
    }
}
